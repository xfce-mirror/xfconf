msgstr "Hataları göndereceğiniz adres: http://bugs.xfce.org/\n"

#: xfconfd/main.c:184
#, c-format
msgid "Error parsing options: %s\n"
msgstr "Seçenekleri ayrıştırmada hata: %s\n"

