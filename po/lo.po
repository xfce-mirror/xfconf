#: xfconf/xfconf-cache.c:987
msgid "Failed to make ResetProperty DBus call"
msgstr "ລົ້ມເຫຼວໃນການຮຽກໃຊ້ DBus ResetProperty"

#: xfconfd/xfconf-backend-perchannel-xml.c:276
#, c-format
msgid "Unable to create configuration directory \"%s\""
msgstr "ບໍ່ສາມາດສ້າງໄດເຣັກທໍຣີການຕັ້ງຄ່າ \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:321 xfconfd/xfconf-daemon.c:167
#, c-format
msgid "Permission denied while modifying property \"%s\" on channel \"%s\""
msgstr "ຖືກປະຕິເສດສິດໃນຂະນະທີ່ກຳລັງປ່ຽນແປງຄຸນສົມບັດ \"%s\" ໃນຊ່ອງ \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:386
#: xfconfd/xfconf-backend-perchannel-xml.c:468
#: xfconfd/xfconf-backend-perchannel-xml.c:633
#: xfconfd/xfconf-backend-perchannel-xml.c:653 xfconf-query/main.c:335
#, c-format
msgid "Property \"%s\" does not exist on channel \"%s\""
msgstr "ຄຸນສົມບັດ \"%s\" ບໍ່ມີຢູ່ໃນຊ່ອງ \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:600
#, c-format
msgid "Unable to remove channel \"%s\": %s"
msgstr "ບໍ່ສາມາດລຶບຊ່ອງ \"%s\": %s"

#: xfconfd/xfconf-backend-perchannel-xml.c:1297
#, c-format
msgid "Invalid type for <property>: \"%s\""
msgstr "ປະເພດບໍ່ຖືກຕ້ອງສຳລັບ <property>: \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1313
#: xfconfd/xfconf-backend-perchannel-xml.c:1389
#, c-format
msgid "Unable to parse value of type \"%s\" from \"%s\""
msgstr "ບໍ່ສາມາດວິເຄາະຄ່າຂອງປະເພດ \"%s\" ຈາກ \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1369
msgid "The type attribute of <value> cannot be an array"
msgstr "ຄຸນລັກສະນະປະເພດຂອງ <value> ບໍ່ສາມາດເປັນອາເຣໄດ້"

#: xfconfd/xfconf-backend-perchannel-xml.c:1378
#, c-format
msgid "Invalid type for <value>: \"%s\""
msgstr "ປະເພດບໍ່ຖືກຕ້ອງສຳລັບ <value>: \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1654
#: xfconfd/xfconf-backend-perchannel-xml.c:1904
#, c-format
msgid "Channel \"%s\" does not exist"
msgstr "ຊ່ອງ \"%s\" ບໍ່ມີຢູ່"

#: xfconfd/xfconf-backend-perchannel-xml.c:1966
#, c-format
msgid "Unable to write channel \"%s\": %s"
msgstr "ບໍ່ສາມາດຂຽນຂໍ້ມູນລົງຊ່ອງ \"%s\": %s"

#: xfconfd/xfconf-backend-factory.c:77
#, c-format
msgid "Unable to find Xfconf backend of type \"%s\""
msgstr "ບໍ່ສາມາດຊອກຫາສ່ວນຫຼັງ (backend) ຂອງ Xfconf ປະເພດ \"%s\""

#: xfconfd/xfconf-backend.c:127
msgid "Property names must start with a '/' character"
msgstr "ຊື່ຄຸນສົມບັດຕ້ອງເລີ່ມຕົ້ນດ້ວຍຕົວອັກສອນ '/'"

#: xfconfd/xfconf-backend.c:136
msgid "The root element ('/') is not a valid property name"
msgstr "ອົງປະກອບຮາກ ('/') ບໍ່ແມ່ນຊື່ຄຸນສົມບັດທີ່ຖືກຕ້ອງ"

#: xfconfd/xfconf-backend.c:151
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "ຊື່ຄຸນສົມບັດສາມາດປະກອບມີພຽງແຕ່ຕົວອັກສອນ ASCII A-Z, a-z, 0-9, '_', '-', ':', '.', ',', '[', ']', '{', '}', '<' ແລະ '>', ລວມທັງ '/' ທີ່ໃຊ້ເປັນຕົວກັ້ນ"

#: xfconfd/xfconf-backend.c:160
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "ຊື່ຄຸນສົມບັດບໍ່ສາມາດມີຕົວອັກສອນ '/' ສອງຕົວ ຫຼື ຫຼາຍກວ່ານັ້ນລຽງຕິດກັນ"

#: xfconfd/xfconf-backend.c:171
msgid "Property names cannot end with a '/' character"
msgstr "ຊື່ຄຸນສົມບັດບໍ່ສາມາດລົງທ້າຍດ້ວຍຕົວອັກສອນ '/'"

#: xfconfd/xfconf-backend.c:188
msgid "Channel name cannot be an empty string"
msgstr "ຊື່ຊ່ອງບໍ່ສາມາດເປັນຄ່າຫວ່າງໄດ້"

#: xfconfd/xfconf-backend.c:203
msgid ""
"Channel names can only include the ASCII characters A-Z, a-z, 0-9, '{', '}',"
" '|', ']', '[', ':', ',', '.', '_', and '-'"
msgstr "ຊື່ຊ່ອງສາມາດປະກອບມີພຽງແຕ່ຕົວອັກສອນ ASCII A-Z, a-z, 0-9, '{', '}', '|', ']', '[', ':', ',', '.', '_', ແລະ '-'"

#: xfconfd/xfconf-backend.c:425
msgid ""
"The property name can only be empty or \"/\" if a recursive reset was "
"specified"
msgstr "ຊື່ຄຸນສົມບັດສາມາດເປັນຄ່າຫວ່າງ ຫຼື \"/\" ໄດ້ພຽງແຕ່ເມື່ອມີການກຳນົດການຕັ້ງຄ່າໃໝ່ແບບຄືນຮູບ (recursive reset) ເທົ່ານັ້ນ"

#: xfconfd/main.c:152
msgid "Prints the xfconfd version."
msgstr "ສະແດງເວີຊັນຂອງ xfconfd"

#: xfconfd/main.c:154
msgid ""
"Configuration backends to use.  The first backend specified is opened "
"read/write; the others, read-only."
msgstr "ສ່ວນຫຼັງການຕັ້ງຄ່າທີ່ຈະໃຊ້. ສ່ວນຫຼັງທຳອິດທີ່ລະບຸຈະຖືກເປີດແບບ ອ່ານ/ຂຽນ; ສ່ວນອື່ນໆແມ່ນ ອ່ານຢ່າງດຽວ."

#: xfconfd/main.c:157
msgid "Fork into background after starting; only useful for testing purposes"
msgstr "ແຍກໄປເຮັດວຽກຢູ່ເບື້ອງຫຼັງຫຼັງຈາກເລີ່ມຕົ້ນ; ມີປະໂຫຍດສະເພາະການທົດສອບເທົ່ານັ້ນ"

#: xfconfd/main.c:176
msgid "Xfce Configuration Daemon"
msgstr "ເດມອນການຕັ້ງຄ່າ Xfce"

#: xfconfd/main.c:181
msgid "Xfce configuration daemon"
msgstr "ເດມອນການຕັ້ງຄ່າ Xfce"

#: xfconfd/main.c:183
msgid "Report bugs to http://bugs.xfce.org/\n"
msgstr "ລາຍງານຂໍ້ຜິດພາດໄປທີ່ http://bugs.xfce.org/\n"

#: xfconfd/main.c:186
#, c-format
msgid "Error parsing options: %s\n"
msgstr "ຂໍ້ຜິດພາດໃນການວິເຄາະຕົວເລືອກ: %s\n"

#: xfconfd/xfconf-daemon.c:222
#, c-format
msgid "GType transformation failed \"%s\""
msgstr "ການແປງ GType ລົ້ມເຫຼວ \"%s\""

#: xfconfd/xfconf-daemon.c:482
msgid "No backends could be started"
msgstr "ບໍ່ສາມາດເລີ່ມຕົ້ນສ່ວນຫຼັງ (backend) ໃດໆໄດ້"

#: xfconf-query/main.c:84 xfconf-query/main.c:89
msgid "set"
msgstr "ຕັ້ງຄ່າ"

#: xfconf-query/main.c:94
msgid "reset"
msgstr "ຕັ້ງຄ່າໃໝ່"

#: xfconf-query/main.c:170
msgid "Version information"
msgstr "ຂໍ້ມູນເວີຊັນ"

#: xfconf-query/main.c:174
msgid "The channel to query/modify"
msgstr "ຊ່ອງທີ່ຈະສອບຖາມ/ປ່ຽນແປງ"

#: xfconf-query/main.c:178
msgid "The property to query/modify"
msgstr "ຄຸນສົມບັດທີ່ຈະສອບຖາມ/ປ່ຽນແປງ"

#: xfconf-query/main.c:182
msgid "The new value to set for the property"
msgstr "ຄ່າໃໝ່ທີ່ຈະຕັ້ງໃຫ້ຄຸນສົມບັດ"

#: xfconf-query/main.c:186
msgid "List properties (or channels if -c is not specified)"
msgstr "ລາຍຊື່ຄຸນສົມບັດ (ຫຼື ຊ່ອງ ຖ້າບໍ່ໄດ້ລະບຸ -c)"

#: xfconf-query/main.c:190
msgid "Print property and value in combination with -l or -m"
msgstr "ສະແດງຄຸນສົມບັດ ແລະ ຄ່າ ຮ່ວມກັບ -l ຫຼື -m"

#: xfconf-query/main.c:194
msgid "Create a new property if it does not already exist"
msgstr "ສ້າງຄຸນສົມບັດໃໝ່ຫາກຍັງບໍ່ມີເທື່ອ"

#: xfconf-query/main.c:198
msgid "Specify the property value type"
msgstr "ລະບຸປະເພດຄ່າຂອງຄຸນສົມບັດ"

#: xfconf-query/main.c:202
msgid "Reset property"
msgstr "ຕັ້ງຄຸນສົມບັດຄືນໃໝ່"

#: xfconf-query/main.c:206
msgid "Recursive (use with -r)"
msgstr "ແບບຄືນຮູບ (ໃຊ້ຮ່ວມກັບ -r)"

#: xfconf-query/main.c:210
msgid "Force array even if only one element"
msgstr "ບັງຄັບໃຫ້ເປັນອາເຣ ເຖິງແມ່ນວ່າມີພຽງອົງປະກອບດຽວ"

#: xfconf-query/main.c:214
msgid "Invert an existing boolean property"
msgstr "ກັບຄ່າຄຸນສົມບັດບູລີນທີ່ມີຢູ່"

#: xfconf-query/main.c:218
msgid "Monitor a channel for property changes"
msgstr "ເຝົ້າຕິດຕາມການປ່ຽນແປງຄຸນສົມບັດໃນຊ່ອງ"

#: xfconf-query/main.c:234
msgid "- Xfconf commandline utility"
msgstr "- ເຄື່ອງມືບັນທັດຄຳສັ່ງ Xfconf"

#: xfconf-query/main.c:239
#, c-format
msgid "Option parsing failed: %s"
msgstr "ການວິເຄາະຕົວເລືອກລົ້ມເຫຼວ: %s"

#: xfconf-query/main.c:249
msgid "The Xfce development team. All rights reserved."
msgstr "ທີມງານພັດທະນາ Xfce. ສະຫງວນລິຂະສິດທັງໝົດ."

#: xfconf-query/main.c:250
#, c-format
msgid "Please report bugs to <%s>."
msgstr "ກະລຸນາລາຍງານຂໍ້ຜິດພາດໄປທີ່ <%s>."

#: xfconf-query/main.c:259
msgid "No property specified"
msgstr "ບໍ່ໄດ້ລະບຸຄຸນສົມບັດ"

#: xfconf-query/main.c:265
msgid "--create and --reset options can not be used together"
msgstr "ຕົວເລືອກ --create ແລະ --reset ບໍ່ສາມາດໃຊ້ຮ່ວມກັນໄດ້"

#: xfconf-query/main.c:271
msgid "--create and --reset options can not be used together with --list"
msgstr "ຕົວເລືອກ --create ແລະ --reset ບໍ່ສາມາດໃຊ້ຮ່ວມກັບ --list ໄດ້"

#: xfconf-query/main.c:277
#, c-format
msgid "Failed to init libxfconf: %s"
msgstr "ລົ້ມເຫຼວໃນການເລີ່ມຕົ້ນ libxfconf: %s"

#: xfconf-query/main.c:288
msgid "Channels:"
msgstr "ຊ່ອງ:"

#: xfconf-query/main.c:313
#, c-format
msgid "Start monitoring channel \"%s\":"
msgstr "ເລີ່ມຕົ້ນເຝົ້າຕິດຕາມຊ່ອງ \"%s\":"

#: xfconf-query/main.c:351 xfconf-query/main.c:462 xfconf-query/main.c:535
msgid "Failed to set property"
msgstr "ຕັ້ງຄ່າຄຸນສົມບັດລົ້ມເຫຼວ"

#: xfconf-query/main.c:355
msgid "--toggle only works with boolean values"
msgstr "--toggle ໃຊ້ໄດ້ກັບຄ່າບູລີນເທົ່ານັ້ນ"

#: xfconf-query/main.c:364 xfconf-query/main.c:383
msgid "(unknown)"
msgstr "(ບໍ່ຮູ້ຈັກ)"

#: xfconf-query/main.c:373
#, c-format
msgid "Value is an array with %d items:"
msgstr "ຄ່າແມ່ນອາເຣທີ່ມີ %d ລາຍການ:"

#: xfconf-query/main.c:397
#, c-format
msgid ""
"Property \"%s\" does not exist on channel \"%s\". If a new property should "
"be created, use the --create option"
msgstr "ຄຸນສົມບັດ \"%s\" ບໍ່ມີຢູ່ໃນຊ່ອງ \"%s\". ຫາກຕ້ອງການສ້າງຄຸນສົມບັດໃໝ່, ໃຫ້ໃຊ້ຕົວເລືອກ --create"

#: xfconf-query/main.c:406
msgid "When creating a new property, the value type must be specified"
msgstr "ເມື່ອສ້າງຄຸນສົມບັດໃໝ່, ຕ້ອງລະບຸປະເພດຂອງຄ່າ"

#: xfconf-query/main.c:417
msgid "Failed to get the existing type for the value"
msgstr "ບໍ່ສາມາດດຶງຂໍ້ມູນປະເພດທີ່ມີຢູ່ສຳລັບຄ່ານັ້ນໄດ້"

#: xfconf-query/main.c:436
msgid "Unable to determine the type of the value"
msgstr "ບໍ່ສາມາດກຳນົດປະເພດຂອງຄ່າໄດ້"

#: xfconf-query/main.c:443
msgid "A value type must be specified to change an array into a single value"
msgstr "ຕ້ອງລະບຸປະເພດຂອງຄ່າເພື່ອປ່ຽນອາເຣໃຫ້ເປັນຄ່າດຽວ"

#: xfconf-query/main.c:454 xfconf-query/main.c:519
#, c-format
msgid "Unable to convert \"%s\" to type \"%s\""
msgstr "ບໍ່ສາມາດແປງ \"%s\" ເປັນປະເພດ \"%s\""

#: xfconf-query/main.c:488
#, c-format
msgid "There are %d new values, but only %d types could be determined"
msgstr "ມີ %d ຄ່າໃໝ່, ແຕ່ສາມາດກຳນົດໄດ້ພຽງ %d ປະເພດເທົ່ານັ້ນ"

#: xfconf-query/main.c:510
#, c-format
msgid "Unable to determine type of value at index %d"
msgstr "ບໍ່ສາມາດກຳນົດປະເພດຂອງຄ່າທີ່ລຳດັບ %d"

#: xfconf-query/main.c:563
#, c-format
msgid "Channel \"%s\" contains no properties"
msgstr "ຊ່ອງ \"%s\" ບໍ່ມີຄຸນສົມບັດໃດໆ"
