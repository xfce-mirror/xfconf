msgstr "Kanaal '%s' bestaat niet"

#: xfconfd/xfconf-backend-perchannel-xml.c:2020
#, c-format
msgid "Unable to write channel \"%s\": %s"
msgstr "Kon kanaal '%s' niet schrijven: %s"

#: xfconfd/xfconf-backend-factory.c:74
#, c-format
msgid "Unable to find Xfconf backend of type \"%s\""
msgstr "Kon geen Xfconf-dienst vinden van het type '%s'"

#: xfconfd/xfconf-backend.c:121
msgid "Property names must start with a '/' character"
msgstr "Eigenschapnamen moeten beginnen met het teken '/'"

#: xfconfd/xfconf-backend.c:130
msgid "The root element ('/') is not a valid property name"
msgstr "Het root-element ('/') is geen geldige eigenschapnaam"

#: xfconfd/xfconf-backend.c:145
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "Eigenschapnamen kunnen slechts de ASCII-tekens A-Z, a-z, 0-9, '_', '-', ':', '.', ',', '[', ']', '{', '}', '<' en '>' bevatten, alsook '/' als een scheidingsteken"

#: xfconfd/xfconf-backend.c:154
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "Eigenschapnamen kunnen niet twee of meer opeenvolgende '/' tekens bevatten"

#: xfconfd/xfconf-backend.c:165
msgid "Property names cannot end with a '/' character"
msgstr "Eigenschapnamen kunnen niet eindigen met een '/'-teken"

#: xfconfd/xfconf-backend.c:182
msgid "Channel name cannot be an empty string"
msgstr "Kanaalnaam kan geen leeg tekstsnoer zijn"

#: xfconfd/xfconf-backend.c:197
msgid ""
"Channel names can only include the ASCII characters A-Z, a-z, 0-9, '{', '}',"
" '|', ']', '[', ':', ',', '.', '_', and '-'"
msgstr "Kanaalnamen kunnen slechts de ASCII-tekens A-Z, a-z, 0-9, '{', '}', '|', ']', '[', ':', ',', '.', '_', en '-' bevatten"

#: xfconfd/xfconf-backend.c:430
msgid ""
"The property name can only be empty or \"/\" if a recursive reset was "
"specified"
msgstr "De eigenschapnaam kan alleen leeg of '/' zijn, als er een recursieve terugzetting werd opgegeven"

#: xfconfd/main.c:148
msgid "Prints the xfconfd version."
msgstr "Drukt de versie van xfconfd af."

#: xfconfd/main.c:150
msgid ""
"Configuration backends to use.  The first backend specified is opened "
"read/write; the others, read-only."
msgstr "Configuratiediensten die u kunt gebruiken. De eerst opgegeven dienst wordt lezen/schrijven geopend; de andere, alleen-lezen."

#: xfconfd/main.c:154
msgid "Fork into background after starting; only useful for testing purposes"
msgstr "Vork in de achtergrond na het starten, alleen nuttig voor proefdoeleinden"

#: xfconfd/main.c:174
msgid "Xfce Configuration Daemon"
msgstr "Achtergronddienst van Xfce Configuratie"

#: xfconfd/main.c:179
msgid "Xfce configuration daemon"
msgstr "Achtergronddienst van Xfce-configuratie"

#: xfconfd/main.c:181
msgid "Report bugs to http://bugs.xfce.org/\n"
msgstr "Meld fouten a.u.b. op http://bugs.xfce.org/\n"

#: xfconfd/main.c:184
#, c-format
msgid "Error parsing options: %s\n"
msgstr "Kon de opties niet lezen: %s\n"

#: xfconfd/xfconf-daemon.c:216
#, c-format
msgid "GType transformation failed \"%s\""
msgstr "GType-transformatie is mislukt '%s'"

#: xfconfd/xfconf-daemon.c:484
msgid "No backends could be started"
msgstr "Er konden geen configuratiediensten worden gestart"

