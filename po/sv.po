#, c-format
msgid "Property \"%s\" does not exist on channel \"%s\""
msgstr "Egenskapen \"%s\" finns inte på kanalen \"%s\""

#: xfconf/xfconf-cache.c:1078
msgid "Failed to make ResetProperty DBus call"
msgstr "Misslyckades med att göra ResetProperty DBus-anrop"

#: xfconfd/xfconf-backend-perchannel-xml.c:272
#, c-format
msgid "Unable to create configuration directory \"%s\""
msgstr "Det gick inte att skapa konfigurationskatalog \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:317 xfconfd/xfconf-daemon.c:164
#, c-format
msgid "Permission denied while modifying property \"%s\" on channel \"%s\""
msgstr "Åtkomst nekad vid ändring av egenskapen \"%s\" på kanalen \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:603
#, c-format
msgid "Unable to remove channel \"%s\": %s"
msgstr "Det gick inte att ta bort kanal \"%s\": %s"

#: xfconfd/xfconf-backend-perchannel-xml.c:1322
#, c-format
msgid "Invalid type for <property>: \"%s\""
msgstr "Ogiltig typ för <property>: \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1339
#: xfconfd/xfconf-backend-perchannel-xml.c:1417
#, c-format
msgid "Unable to parse value of type \"%s\" from \"%s\""
msgstr "Det gick inte att tolka värdet av typ \"%s\" från \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1397
msgid "The type attribute of <value> cannot be an array"
msgstr "Typattributet för <value> kan inte vara en samling"

#: xfconfd/xfconf-backend-perchannel-xml.c:1406
#, c-format
msgid "Invalid type for <value>: \"%s\""
msgstr "Ogiltig typ för <value>: \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1686
#: xfconfd/xfconf-backend-perchannel-xml.c:1949
#, c-format
msgid "Channel \"%s\" does not exist"
msgstr "Kanalen \"%s\" finns inte"

#: xfconfd/xfconf-backend-perchannel-xml.c:2020
#, c-format
msgid "Unable to write channel \"%s\": %s"
msgstr "Det gick inte att skriva kanal \"%s\": %s"

#: xfconfd/xfconf-backend-factory.c:74
#, c-format
msgid "Unable to find Xfconf backend of type \"%s\""
msgstr "Det gick inte att hitta Xfconf-bakände av typen \"%s\""

#: xfconfd/xfconf-backend.c:121
msgid "Property names must start with a '/' character"
msgstr "Egenskapsnamn måste inledas med ett \"/\"-tecken"

#: xfconfd/xfconf-backend.c:130
msgid "The root element ('/') is not a valid property name"
msgstr "Rotelementet (\"/\") är inte ett giltigt egenskapsnamn"

#: xfconfd/xfconf-backend.c:145
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "Egenskapsnamn kan endast innehålla ASCII-tecknen A-Z, a-z, 0-9, '_', '-', ':', '.', ',', '[', ']', '{', '}', '<' och '>', liksom '/' som en separator"

#: xfconfd/xfconf-backend.c:154
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "Egenskapsnamn får inte innehålla två eller flera \"/\"-tecken i rad"

#: xfconfd/xfconf-backend.c:165
msgid "Property names cannot end with a '/' character"
msgstr "Egenskapsnamn får inte sluta med ett \"/\"-tecken"

#: xfconfd/xfconf-backend.c:182
msgid "Channel name cannot be an empty string"
msgstr "Kanalnamn får inte vara en tom sträng"

#: xfconfd/xfconf-backend.c:197
msgid ""
"Channel names can only include the ASCII characters A-Z, a-z, 0-9, '{', '}',"
" '|', ']', '[', ':', ',', '.', '_', and '-'"
msgstr "Kanalnamn kan endast innehålla ASCII-tecknen A-Z, a-z, 0-9, '{', '}', '|', ']', '[', ':', ',', '.', '_', och '-'"

#: xfconfd/xfconf-backend.c:430
msgid ""
"The property name can only be empty or \"/\" if a recursive reset was "
"specified"
msgstr "Egenskapsnamnet får endast vara tomt eller \"/\" om en rekursiv nollställning angavs"

#: xfconfd/main.c:148
msgid "Prints the xfconfd version."
msgstr "Skriver ut xfconfd-versionen."

#: xfconfd/main.c:150
msgid ""
"Configuration backends to use.  The first backend specified is opened "
"read/write; the others, read-only."
msgstr "Konfigurationsbakände att använda.  Första bakänden som anges öppnas läs/skriv; de andra som skivskyddade."

#: xfconfd/main.c:154
msgid "Fork into background after starting; only useful for testing purposes"
msgstr "Grena processen till bakgrunden efter start; endast användbart för testsyfte"

#: xfconfd/main.c:174
msgid "Xfce Configuration Daemon"
msgstr "Konfigurationsdemon för Xfce"

#: xfconfd/main.c:179
msgid "Xfce configuration daemon"
msgstr "Konfigurationsdemon för Xfce"

#: xfconfd/main.c:181
msgid "Report bugs to http://bugs.xfce.org/\n"
msgstr "Rapportera fel till http://bugs.xfce.org/\n"

#: xfconfd/main.c:184
#, c-format
msgid "Error parsing options: %s\n"
msgstr "Fel vid tolkning av flaggor: %s\n"

#: xfconfd/xfconf-daemon.c:216
#, c-format
msgid "GType transformation failed \"%s\""
msgstr "GType-omvandling misslyckades \"%s\""

#: xfconfd/xfconf-daemon.c:484
msgid "No backends could be started"
msgstr "Inga bakändar kunde startas"

#. TRANSLATORS: This refers to: "A property has been set"
#: xfconf-query/main.c:113
msgid "set"
msgstr "ställ in"

#. TRANSLATORS: This refers to: "A property has been reset"
#: xfconf-query/main.c:128
msgid "reset"
msgstr "återställ"

#: xfconf-query/main.c:228
msgid "Possible types:"
msgstr "Möjliga typer:"

#: xfconf-query/main.c:237
msgid "Version information"
msgstr "Versionsinformation"

#: xfconf-query/main.c:240
msgid "The channel to query/modify"
msgstr "Kanalen att fråga/ändra"

#: xfconf-query/main.c:243
msgid "The property to query/modify"
msgstr "Egenskapen att fråga/ändra"

#: xfconf-query/main.c:246
msgid "The new value to set for the property (multiple uses for an array)"
msgstr "Det nya värdet att ange för egenskap (flera användningsområden för en array)"

#: xfconf-query/main.c:249
msgid "List properties (or channels if -c is not specified)"
msgstr "Lista egenskaper (eller kanaler om -c inte angivits)"

#: xfconf-query/main.c:252
msgid ""
"Print also the value in combination with -l or -m (use twice to print also "
"the type)"
msgstr "Skriv även ut värdet i kombination med -l eller -m (använd två gånger för att även skriva ut typ)"

#: xfconf-query/main.c:255
msgid "Specify the property value type (multiple uses for an array)"
msgstr "Specificera egenskapsvärdestypen (flera användningsområden för en array)"

#: xfconf-query/main.c:258
msgid "Reset property"
msgstr "Nollställ egenskap"

#: xfconf-query/main.c:261
msgid "Recursive (use with -r)"
msgstr "Rekursiv (använd med -r)"

#: xfconf-query/main.c:264
msgid "Force array even if only one element"
msgstr "Tvinga ordning även om endast ett element"

#: xfconf-query/main.c:267
msgid "Invert an existing boolean property"
msgstr "Kasta om en existerande booleansk egenskap"

#: xfconf-query/main.c:270
msgid "Monitor a channel for property changes"
msgstr "Övervaka en kanal för egenskapsändringar"

#: xfconf-query/main.c:273
msgid "List types that can be specified using the --type option"
msgstr "Lista typer som kan anges genom att använda sig av --type alternativet"

#: xfconf-query/main.c:277
msgid "Create a new property if it does not already exist"
msgstr "Skapa en ny egenskap om den inte redan finns"

#: xfconf-query/main.c:292
msgid "- Xfconf commandline utility"
msgstr "- Xfconf kommandoradsverktyg"

#: xfconf-query/main.c:296
#, c-format
msgid "Option parsing failed: %s"
msgstr "Alternativ tolkning misslyckades: %s"

#: xfconf-query/main.c:307
msgid "The Xfce development team. All rights reserved."
msgstr "Xfce:s utvecklingsteam. Alla rättigheter förbehållna."

#: xfconf-query/main.c:308
#, c-format
msgid "Please report bugs to <%s>."
msgstr "Rapportera gärna fel till <%s>."

#: xfconf-query/main.c:321
msgid "No property specified"
msgstr "Ingen egenskap angiven"

#: xfconf-query/main.c:326
msgid "The property name should start with '/'"
msgstr "Egenskapsnamn ska börja med '/'"

#: xfconf-query/main.c:331
msgid "--set and --reset options can not be used together"
msgstr "--set och --reset alternativen kan inte användas tillsammans"

#: xfconf-query/main.c:336
msgid "--set and --reset options can not be used together with --list"
msgstr "--set och --reset alternativen kan inte användas tillsammans med --list"

#: xfconf-query/main.c:345
#, c-format
msgid "Failed to init libxfconf: %s"
msgstr "Misslyckades initiera libxfconf: %s"

#: xfconf-query/main.c:355
msgid "Channels:"
msgstr "Kanaler:"

#: xfconf-query/main.c:379
#, c-format
msgid "Start monitoring channel \"%s\":"
msgstr "Börja övervaka kanal \"%s\":"

#: xfconf-query/main.c:408 xfconf-query/main.c:512 xfconf-query/main.c:578
msgid "Failed to set property"
msgstr "Misslyckades ställa in egenskapen"

#: xfconf-query/main.c:411
msgid "--toggle only works with boolean values"
msgstr "--toggle fungerar bara med booleanska värden"

#: xfconf-query/main.c:421 xfconf-query/main.c:423 xfconf-query/main.c:441
#: xfconf-query/main.c:443
msgid "(unknown)"
msgstr "(okänt)"

#: xfconf-query/main.c:431
#, c-format
msgid "Value is an array with %d items:"
msgstr "Värdet är en samling med %d poster:"

#: xfconf-query/main.c:456
msgid "When creating a new property, the value type must be specified"
msgstr "Då en ny egenskap skapas, måste värdet specificeras"

#: xfconf-query/main.c:466
msgid "Failed to get the existing type for the value"
msgstr "Misslyckades få den nuvarande typen för värdet"

#: xfconf-query/main.c:485
msgid "Unable to determine the type of the value"
msgstr "Det gick inte att bestämma värdets typ"

#: xfconf-query/main.c:492
msgid "A value type must be specified to change an array into a single value"
msgstr "En värdetyp måste specificeras för att ändra en samling till ett enda värde"

#: xfconf-query/main.c:504 xfconf-query/main.c:561
#, c-format
msgid "Unable to convert \"%s\" to type \"%s\""
msgstr "Det gick inte att konvertera \"%s\" till typ \"%s\""

#: xfconf-query/main.c:532
#, c-format
msgid "There are %d new values, but only %d types could be determined"
msgstr "Det finns %d nya värden, men bara %d typer kunde bestämmas"

#: xfconf-query/main.c:552
#, c-format
msgid "Unable to determine type of value at index %d"
msgstr "Det gick inte att avgöra värdetyp vid index %d"

#: xfconf-query/main.c:603
#, c-format
msgid "Channel \"%s\" contains no properties"
msgstr "Kanal \"%s\" innehåller inga egenskaper"
