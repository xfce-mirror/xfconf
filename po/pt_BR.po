msgstr "Não foi possível remover o canal \"%s\": %s"

#: xfconfd/xfconf-backend-perchannel-xml.c:1322
#, c-format
msgid "Invalid type for <property>: \"%s\""
msgstr "Tipo inválido para <property>: \"%s\""

