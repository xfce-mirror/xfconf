#: xfconf/xfconf-cache.c:850 xfconfd/xfconf-backend-perchannel-xml.c:388
#: xfconfd/xfconf-backend-perchannel-xml.c:473
#: xfconfd/xfconf-backend-perchannel-xml.c:637
#: xfconfd/xfconf-backend-perchannel-xml.c:659 xfconf-query/main.c:362
#, c-format
msgid "Property \"%s\" does not exist on channel \"%s\""
msgstr "Својство „%s“ не постоји на каналу „%s“"

#: xfconf/xfconf-cache.c:1078
msgid "Failed to make ResetProperty DBus call"
msgstr "Нисам успео да направим позив Д-сабирнице поврати својство"

#: xfconfd/xfconf-backend-perchannel-xml.c:272
#, c-format
msgid "Unable to create configuration directory \"%s\""
msgstr "Не могу да направим директоријум подешавања „%s“"

#: xfconfd/xfconf-backend-perchannel-xml.c:317 xfconfd/xfconf-daemon.c:164
#, c-format
msgid "Permission denied while modifying property \"%s\" on channel \"%s\""
msgstr "Одбијено је овлашћење за време измене својства „%s“ на каналу „%s“"

#: xfconfd/xfconf-backend-perchannel-xml.c:603
#, c-format
msgid "Unable to remove channel \"%s\": %s"
msgstr "Не могу да уклоним канал „%s“: %s"

#: xfconfd/xfconf-backend-perchannel-xml.c:1322
#, c-format
msgid "Invalid type for <property>: \"%s\""
msgstr "Неисправна врста за <својство>: „%s“"

#: xfconfd/xfconf-backend-perchannel-xml.c:1339
#: xfconfd/xfconf-backend-perchannel-xml.c:1417
#, c-format
msgid "Unable to parse value of type \"%s\" from \"%s\""
msgstr "Не могу да обрадим вредност врсте „%s“ из „%s“"

#: xfconfd/xfconf-backend-perchannel-xml.c:1397
msgid "The type attribute of <value> cannot be an array"
msgstr "Атрибут врсте <вредности> не може бити низ"

#: xfconfd/xfconf-backend-perchannel-xml.c:1406
#, c-format
msgid "Invalid type for <value>: \"%s\""
msgstr "Неисправна врста за <вредност>: „%s“"

#: xfconfd/xfconf-backend-perchannel-xml.c:1686
#: xfconfd/xfconf-backend-perchannel-xml.c:1949
#, c-format
msgid "Channel \"%s\" does not exist"
msgstr "Канал „%s“ не постоји"

#: xfconfd/xfconf-backend-perchannel-xml.c:2020
#, c-format
msgid "Unable to write channel \"%s\": %s"
msgstr "Не могу да запишем канал „%s“: %s"

#: xfconfd/xfconf-backend-factory.c:74
#, c-format
msgid "Unable to find Xfconf backend of type \"%s\""
msgstr "Не могу да пронађем Иксфконф позадинца врсте „%s“"

#: xfconfd/xfconf-backend.c:121
msgid "Property names must start with a '/' character"
msgstr "Називи својстава морају почињати знаком „/“"

#: xfconfd/xfconf-backend.c:130
msgid "The root element ('/') is not a valid property name"
msgstr "Корени елемент („/“) није исправан назив својства"

#: xfconfd/xfconf-backend.c:145
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "Имена својстава могу само да садрже АСКИИ знаке A-Z, a-z, 0-9, „_“, „-“, „:“, „.“, „,“, „[“, „]“, „{“, „}“, „<“ и „>“,као и „/“ у улози раздвајача"

#: xfconfd/xfconf-backend.c:154
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "Називи својстава не могу имати два или више узастопна знака /"

#: xfconfd/xfconf-backend.c:165
msgid "Property names cannot end with a '/' character"
msgstr "Називи својстава се не могу завршавати знаком /"

#: xfconfd/xfconf-backend.c:182
msgid "Channel name cannot be an empty string"
msgstr "Назив канала не може бити празан"

#: xfconfd/xfconf-backend.c:197
msgid ""
"Channel names can only include the ASCII characters A-Z, a-z, 0-9, '{', '}',"
" '|', ']', '[', ':', ',', '.', '_', and '-'"
msgstr "Имена канала могу да садрже само АСКИИ знаке A-Z, a-z, 0-9, „{“, „}“, „|“, „]“, „[“, „:“, „,“, „.“, „_“, и„-“"

#: xfconfd/xfconf-backend.c:430
msgid ""
"The property name can only be empty or \"/\" if a recursive reset was "
"specified"
msgstr "Назив својства само може бити празан или / ако је наведено дубинско враћање"

#: xfconfd/main.c:148
msgid "Prints the xfconfd version."
msgstr "Исписује издање домара подешавања иксфд-а."

#: xfconfd/main.c:150
msgid ""
"Configuration backends to use.  The first backend specified is opened "
"read/write; the others, read-only."
msgstr "Позадинци подешавања за употребу.  Први позадинац наведен је отворен за читање/писање; остали, само за читање."

#: xfconfd/main.c:154
msgid "Fork into background after starting; only useful for testing purposes"
msgstr "Ствара клицу у позадини након покретања; корисно је само за сврхе испробавања"

#: xfconfd/main.c:174
msgid "Xfce Configuration Daemon"
msgstr "Домар подешавања Иксфце-а"

#: xfconfd/main.c:179
msgid "Xfce configuration daemon"
msgstr "Прибор за подешавање Иксфце-а"

#: xfconfd/main.c:181
msgid "Report bugs to http://bugs.xfce.org/\n"
msgstr "Пријавите грешаке на „http://bugs.xfce.org/“\n"

#: xfconfd/main.c:184
#, c-format
msgid "Error parsing options: %s\n"
msgstr "Грешка обраде могућности: %s\n"

#: xfconfd/xfconf-daemon.c:216
#, c-format
msgid "GType transformation failed \"%s\""
msgstr "Преображај г-врста није успео „%s“"

#: xfconfd/xfconf-daemon.c:484
msgid "No backends could be started"
msgstr "Ни један позадинац не може бити покренут"

#: xfconf-query/main.c:82 xfconf-query/main.c:85
msgid "set"
msgstr "постављено"

#: xfconf-query/main.c:88
msgid "reset"
msgstr "врати"

#: xfconf-query/main.c:194
msgid "Possible types:"
msgstr ""

#: xfconf-query/main.c:203
msgid "Version information"
msgstr "Подаци о издању"

#: xfconf-query/main.c:206
msgid "The channel to query/modify"
msgstr "Канал за пропитивање/измену"

#: xfconf-query/main.c:209
msgid "The property to query/modify"
msgstr "Својство за пропитивање/измену"

#: xfconf-query/main.c:212
msgid "The new value to set for the property (multiple uses for an array)"
msgstr ""

#: xfconf-query/main.c:215
msgid "List properties (or channels if -c is not specified)"
msgstr "Списак својстава (или канала ако „-c“ није наведено)"

#: xfconf-query/main.c:218
msgid "Print property and value in combination with -l or -m"
msgstr "Испиши својство и вредност у помоћу -l или -m"

#: xfconf-query/main.c:221
msgid "Specify the property value type (multiple uses for an array)"
msgstr ""

#: xfconf-query/main.c:224
msgid "Reset property"
msgstr "Враћа својство"

#: xfconf-query/main.c:227
msgid "Recursive (use with -r)"
msgstr "Дубински (користи се са „-r“)"

#: xfconf-query/main.c:230
msgid "Force array even if only one element"
msgstr "Присиљава низ чак и ако је само један елемент"

#: xfconf-query/main.c:233
msgid "Invert an existing boolean property"
msgstr "Преокреће постојеће логичко својство"

#: xfconf-query/main.c:236
msgid "Monitor a channel for property changes"
msgstr "Надгледа канал за изменама својства"

#: xfconf-query/main.c:239
msgid "List types that can be specified using the --type option"
msgstr ""

#: xfconf-query/main.c:243
msgid "Create a new property if it does not already exist"
msgstr "Ствара ново својство ако већ не постоји"

#: xfconf-query/main.c:258
msgid "- Xfconf commandline utility"
msgstr "— Иксф конф алатка линије наредби"

#: xfconf-query/main.c:262
#, c-format
msgid "Option parsing failed: %s"
msgstr "Није успела обрада опције: %s"

#: xfconf-query/main.c:273
msgid "The Xfce development team. All rights reserved."
msgstr "ИксФЦЕ-ova развојна дружина. Сва права су задржана."

#: xfconf-query/main.c:274
#, c-format
msgid "Please report bugs to <%s>."
msgstr "Молим пријавите грешке на <%s>."

#: xfconf-query/main.c:287
msgid "No property specified"
msgstr "Није наведено својство"

#: xfconf-query/main.c:292
msgid "The property name should start with '/'"
msgstr ""

#: xfconf-query/main.c:297
msgid "--set and --reset options can not be used together"
msgstr ""

#: xfconf-query/main.c:302
msgid "--set and --reset options can not be used together with --list"
msgstr ""

#: xfconf-query/main.c:311
#, c-format
msgid "Failed to init libxfconf: %s"
msgstr "Нисам успео да покренем библиотеку иксфконф: %s"

#: xfconf-query/main.c:321
msgid "Channels:"
msgstr "Канали:"

#: xfconf-query/main.c:345
#, c-format
msgid "Start monitoring channel \"%s\":"
msgstr "Почни надгледање канала „%s“:"

#: xfconf-query/main.c:374 xfconf-query/main.c:468 xfconf-query/main.c:534
msgid "Failed to set property"
msgstr "Нисам успео да подесим својство"

#: xfconf-query/main.c:377
msgid "--toggle only works with boolean values"
msgstr "„--toggle“ ради само са логичким вредностима"

#: xfconf-query/main.c:385 xfconf-query/main.c:400
msgid "(unknown)"
msgstr "(непознато)"

#: xfconf-query/main.c:392
#, c-format
msgid "Value is an array with %d items:"
msgstr "Вредност је низ са %d ставком:"

#: xfconf-query/main.c:412
msgid "When creating a new property, the value type must be specified"
msgstr "Када стварате ново својство, врста вредности мора бити наведена"

#: xfconf-query/main.c:422
msgid "Failed to get the existing type for the value"
msgstr "Нисам успео да добавим постојећу врсту за вредност"

#: xfconf-query/main.c:441
msgid "Unable to determine the type of the value"
msgstr "Не могу да одредим врсту за вредност"

#: xfconf-query/main.c:448
msgid "A value type must be specified to change an array into a single value"
msgstr "Врста вредности мора бити наведена зарад промене низа у једну вредност"

#: xfconf-query/main.c:460 xfconf-query/main.c:517
#, c-format
msgid "Unable to convert \"%s\" to type \"%s\""
msgstr "Не могу да претворим „%s“ у врсту „%s“"

#: xfconf-query/main.c:488
#, c-format
msgid "There are %d new values, but only %d types could be determined"
msgstr "Има %d нове вредности, али само %d врсте могу бити одређене"

#: xfconf-query/main.c:508
#, c-format
msgid "Unable to determine type of value at index %d"
msgstr "Не могу да одредим врсту вредности на индексу %d"

#: xfconf-query/main.c:558
#, c-format
msgid "Channel \"%s\" contains no properties"
msgstr "Канал „%s“ не садржи својства"
