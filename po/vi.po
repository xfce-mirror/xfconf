msgstr "Kênh \"%s\" không tồn tại"

#: xfconfd/xfconf-backend-perchannel-xml.c:2020
#, c-format
msgid "Unable to write channel \"%s\": %s"
msgstr "Không thể ghi kênh \"%s\": %s"

#: xfconfd/xfconf-backend-factory.c:74
#, c-format
msgid "Unable to find Xfconf backend of type \"%s\""
msgstr "Không thể tìm thấy phần phụ trợ Xfconf loại \"%s\""

#: xfconfd/xfconf-backend.c:121
msgid "Property names must start with a '/' character"
msgstr "Tên thuộc tính phải bắt đầu bằng ký tự '/'"

#: xfconfd/xfconf-backend.c:130
msgid "The root element ('/') is not a valid property name"
msgstr "Phần tử gốc ('/') không phải là tên thuộc tính hợp lệ"

#: xfconfd/xfconf-backend.c:145
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "Tên thuộc tính chỉ có thể bao gồm các ký tự ASCII A-Z, a-z, 0-9, '_', '-', ':', '.', ',', '[', ']', '{', '}', '<' và '>', cũng như '/' làm dấu phân cách"

#: xfconfd/xfconf-backend.c:154
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "Tên thuộc tính không thể có hai hoặc nhiều ký tự '/' liên tiếp"

#: xfconfd/xfconf-backend.c:165
msgid "Property names cannot end with a '/' character"
msgstr "Tên thuộc tính không thể kết thúc bằng ký tự '/'"

#: xfconfd/xfconf-backend.c:182
msgid "Channel name cannot be an empty string"
msgstr "Tên kênh không thể là một chuỗi trống"

#: xfconfd/xfconf-backend.c:197
msgid ""
"Channel names can only include the ASCII characters A-Z, a-z, 0-9, '{', '}',"
" '|', ']', '[', ':', ',', '.', '_', and '-'"
msgstr "Tên kênh chỉ có thể bao gồm các ký tự ASCII A-Z, a-z, 0-9, '{', '}', '|', ']', '[', ':', ',', '.', '_' và '-'"

#: xfconfd/xfconf-backend.c:430
msgid ""
"The property name can only be empty or \"/\" if a recursive reset was "
"specified"
msgstr "Tên thuộc tính chỉ có thể để trống hoặc \"/\" nếu đặt lại đệ quy được chỉ định"

#: xfconfd/main.c:148
msgid "Prints the xfconfd version."
msgstr "In phiên bản xfconfd."

#: xfconfd/main.c:150
msgid ""
"Configuration backends to use.  The first backend specified is opened "
"read/write; the others, read-only."
msgstr "Cấu hình phụ trợ để sử dụng.  Phần phụ trợ đầu tiên được chỉ định sẽ được mở đọc/ghi; những cái khác, chỉ đọc."

#: xfconfd/main.c:154
msgid "Fork into background after starting; only useful for testing purposes"
msgstr "Chuyển sang nền sau khi bắt đầu; chỉ hữu ích cho mục đích thử nghiệm"

#: xfconfd/main.c:174
msgid "Xfce Configuration Daemon"
msgstr "Trình nền cấu hình Xfce"

#: xfconfd/main.c:179
msgid "Xfce configuration daemon"
msgstr "Trình nền cấu hình Xfce"

#: xfconfd/main.c:181
msgid "Report bugs to http://bugs.xfce.org/\n"
msgstr "Báo cáo lỗi tới http://bugs.xfce.org/\n"

#: xfconfd/main.c:184
#, c-format
msgid "Error parsing options: %s\n"
msgstr "Tùy chọn phân tích cú pháp lỗi: %s\n"

#: xfconfd/xfconf-daemon.c:216
#, c-format
msgid "GType transformation failed \"%s\""
msgstr "Chuyển đổi GType không thành công \"%s\""

#: xfconfd/xfconf-daemon.c:484
msgid "No backends could be started"
msgstr "Không có chương trình phụ trợ nào có thể được bắt đầu"

