msgstr "L'equipa de desvolopament de XFCE. Totes los dreits reservats."

#: xfconf-query/main.c:274
#, c-format
msgid "Please report bugs to <%s>."
msgstr "Se vos plai raportatz los bugs a <%s>."

#: xfconf-query/main.c:287
msgid "No property specified"
msgstr "Cap de proprietat pas especificada"

#: xfconf-query/main.c:292
msgid "The property name should start with '/'"
msgstr ""

