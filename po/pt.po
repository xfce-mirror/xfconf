msgstr "Incapaz de processar o valor do tipo \"%s\" em \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1397
msgid "The type attribute of <value> cannot be an array"
msgstr "O tipo de atributo de <value> não pode ser uma matriz"

#: xfconfd/xfconf-backend-perchannel-xml.c:1406
#, c-format
msgid "Invalid type for <value>: \"%s\""
msgstr "Tipo inválido para <value>: \"%s\""

#: xfconfd/xfconf-backend-perchannel-xml.c:1686
#: xfconfd/xfconf-backend-perchannel-xml.c:1949
#, c-format
msgid "Channel \"%s\" does not exist"
msgstr "O canal \"%s\" não existe"

#: xfconfd/xfconf-backend-perchannel-xml.c:2020
#, c-format
msgid "Unable to write channel \"%s\": %s"
msgstr "Incapaz de escrever o canal \"%s\": %s"

#: xfconfd/xfconf-backend-factory.c:74
#, c-format
msgid "Unable to find Xfconf backend of type \"%s\""
msgstr "Incapaz de encontrar a infraestrutura Xfconf do tipo \"%s\""

#: xfconfd/xfconf-backend.c:121
msgid "Property names must start with a '/' character"
msgstr "Os nomes das propriedades devem começar com o carácter '/'"

#: xfconfd/xfconf-backend.c:130
msgid "The root element ('/') is not a valid property name"
msgstr "O elemento root ('/') não é um nome de propriedade válido"

#: xfconfd/xfconf-backend.c:145
msgid ""
"Property names can only include the ASCII characters A-Z, a-z, 0-9, '_', "
"'-', ':', '.', ',', '[', ']', '{', '}', '<' and '>', as well as '/' as a "
"separator"
msgstr "Nomes de propriedades apenas podem incluir carateres ASCII A-Z, a-z, 0-9, '_', '-', ':', '.', ',', '[', ']', '{', '}', '<' e '>', assim como '/' como separador"

#: xfconfd/xfconf-backend.c:154
msgid "Property names cannot have two or more consecutive '/' characters"
msgstr "Os nomes de propriedades não podem ter dois ou mais caracteres '/' sequenciais"

#: xfconfd/xfconf-backend.c:165
msgid "Property names cannot end with a '/' character"
msgstr "Os nomes de propriedades não podem terminar com o carácter '/'"

#: xfconfd/xfconf-backend.c:182
msgid "Channel name cannot be an empty string"
msgstr "O nome do canal não pode estar vazio"

#: xfconfd/xfconf-backend.c:197
msgid ""
"Channel names can only include the ASCII characters A-Z, a-z, 0-9, '{', '}',"
" '|', ']', '[', ':', ',', '.', '_', and '-'"
msgstr "Nomes de canal podem incluir apenas carateres ASCII A-Z, a-z, 0-9, '{', '}', '|', ']', '[', ':', ',', '.', '_', e '-'"

#: xfconfd/xfconf-backend.c:430
msgid ""
"The property name can only be empty or \"/\" if a recursive reset was "
"specified"
msgstr "O nome da propriedade só pode ser vazio ou \"/\" se indicar um reposição recursiva"

#: xfconfd/main.c:148
msgid "Prints the xfconfd version."
msgstr "Mostra a versão do xfconfd."

#: xfconfd/main.c:150
msgid ""
"Configuration backends to use.  The first backend specified is opened "
"read/write; the others, read-only."
msgstr "A configuração de infraestrutura usada. A primeira infraestrutura especificada é aberta em leitura/escrita, as outras só de leitura."

#: xfconfd/main.c:154
msgid "Fork into background after starting; only useful for testing purposes"
msgstr "Ao iniciar, enviar para segundo plano. Só útil para testes"

#: xfconfd/main.c:174
msgid "Xfce Configuration Daemon"
msgstr "Serviço de configurações do Xfce"

#: xfconfd/main.c:179
msgid "Xfce configuration daemon"
msgstr "Serviço de configurações do Xfce"

#: xfconfd/main.c:181
msgid "Report bugs to http://bugs.xfce.org/\n"
msgstr "Reporte os erros em http://bugs.xfce.org/\n"

#: xfconfd/main.c:184
#, c-format
msgid "Error parsing options: %s\n"
msgstr "Erro ao processar as opções: %s\n"

#: xfconfd/xfconf-daemon.c:216
#, c-format
msgid "GType transformation failed \"%s\""
msgstr "Transformação GType falhou \"%s\""

#: xfconfd/xfconf-daemon.c:484
msgid "No backends could be started"
msgstr "Nenhuma infraestrutura iniciada"

#. TRANSLATORS: This refers to: "A property has been set"
#: xfconf-query/main.c:113
msgid "set"
msgstr "definir"

#. TRANSLATORS: This refers to: "A property has been reset"
#: xfconf-query/main.c:128
msgid "reset"
msgstr "repor"

#: xfconf-query/main.c:228
msgid "Possible types:"
msgstr "Tipos possíveis:"

#: xfconf-query/main.c:237
msgid "Version information"
msgstr "Informações da versão"

#: xfconf-query/main.c:240
msgid "The channel to query/modify"
msgstr "O canal a consultar/modificar"

#: xfconf-query/main.c:243
msgid "The property to query/modify"
msgstr "A propriedade a consultar/modificar"

#: xfconf-query/main.c:246
msgid "The new value to set for the property (multiple uses for an array)"
msgstr "O novo valor a definir para a propriedade (várias utilizações para uma matriz)"

#: xfconf-query/main.c:249
msgid "List properties (or channels if -c is not specified)"
msgstr "Listar propriedades (ou canais se -c não especificado)"

#: xfconf-query/main.c:252
msgid ""
"Print also the value in combination with -l or -m (use twice to print also "
"the type)"
msgstr "Exibir também o valor em combinação com -l ou -m (utilizar duas vezes para exibir também o tipo)"

#: xfconf-query/main.c:255
msgid "Specify the property value type (multiple uses for an array)"
msgstr "Especifique o tipo de valor da propriedade (utilizações múltiplas para uma matriz)"

#: xfconf-query/main.c:258
msgid "Reset property"
msgstr "Repor propriedade"

#: xfconf-query/main.c:261
msgid "Recursive (use with -r)"
msgstr "Recursivo (usar com -r)"

#: xfconf-query/main.c:264
msgid "Force array even if only one element"
msgstr "Forçar matriz, mesmo que só exista um elemento"

#: xfconf-query/main.c:267
msgid "Invert an existing boolean property"
msgstr "Inverter a propriedade booleana existente"

#: xfconf-query/main.c:270
msgid "Monitor a channel for property changes"
msgstr "Monitorizar um canal por mudanças de propriedades"

#: xfconf-query/main.c:273
msgid "List types that can be specified using the --type option"
msgstr "Enumerar os tipos que podem ser especificados utilizando a opção --type"

#: xfconf-query/main.c:277
msgid "Create a new property if it does not already exist"
msgstr "Criar nova propriedade se não existente"

#: xfconf-query/main.c:292
msgid "- Xfconf commandline utility"
msgstr "- utilitário de linha de comando Xfconf"

#: xfconf-query/main.c:296
#, c-format
msgid "Option parsing failed: %s"
msgstr "Falha ao processar a opção: %s"

#: xfconf-query/main.c:307
msgid "The Xfce development team. All rights reserved."
msgstr "A equipa de desenvolvimento do Xfce. Todos os direitos reservados."

#: xfconf-query/main.c:308
#, c-format
msgid "Please report bugs to <%s>."
msgstr "Por favor, reporte os erros em <%s>."

#: xfconf-query/main.c:321
msgid "No property specified"
msgstr "Nenhuma propriedade especificada"

#: xfconf-query/main.c:326
msgid "The property name should start with '/'"
msgstr "O nome da propriedade deve começar por '/'"

#: xfconf-query/main.c:331
msgid "--set and --reset options can not be used together"
msgstr "As opções --set e --reset não podem ser utilizadas em simultâneo"

#: xfconf-query/main.c:336
msgid "--set and --reset options can not be used together with --list"
msgstr "As opções --set e --reset não podem ser utilizadas em conjunto com a opção --list"

#: xfconf-query/main.c:345
#, c-format
msgid "Failed to init libxfconf: %s"
msgstr "Falha ao iniciar libxfconf: %s"

#: xfconf-query/main.c:355
msgid "Channels:"
msgstr "Canais:"

#: xfconf-query/main.c:379
#, c-format
msgid "Start monitoring channel \"%s\":"
msgstr "Iniciar monitorização do canal \"%s\":"

#: xfconf-query/main.c:408 xfconf-query/main.c:512 xfconf-query/main.c:578
msgid "Failed to set property"
msgstr "Falha ao definir a propriedade"

#: xfconf-query/main.c:411
msgid "--toggle only works with boolean values"
msgstr "--toggle só funciona com valores booleanos"

#: xfconf-query/main.c:421 xfconf-query/main.c:423 xfconf-query/main.c:441
#: xfconf-query/main.c:443
msgid "(unknown)"
msgstr "(desconhecido)"

#: xfconf-query/main.c:431
#, c-format
msgid "Value is an array with %d items:"
msgstr "O valor é uma matriz com %d itens:"

#: xfconf-query/main.c:456
msgid "When creating a new property, the value type must be specified"
msgstr "Ao criar uma nova propriedade, deve especificar o tipo"

#: xfconf-query/main.c:466
msgid "Failed to get the existing type for the value"
msgstr "Falha ao obter o tipo de valor existente"

#: xfconf-query/main.c:485
msgid "Unable to determine the type of the value"
msgstr "Incapaz de determinar o tipo de valor"

#: xfconf-query/main.c:492
msgid "A value type must be specified to change an array into a single value"
msgstr "Deve especificar o tipo de valor para converter uma matriz num valor único"

#: xfconf-query/main.c:504 xfconf-query/main.c:561
#, c-format
msgid "Unable to convert \"%s\" to type \"%s\""
msgstr "Incapaz de converter \"%s\" para o tipo \"%s\""

#: xfconf-query/main.c:532
#, c-format
msgid "There are %d new values, but only %d types could be determined"
msgstr "Existem %d novos valores, mas só %d tipos foram determinados"

#: xfconf-query/main.c:552
#, c-format
msgid "Unable to determine type of value at index %d"
msgstr "Incapaz de determinar o tipo de valor no índice %d"

#: xfconf-query/main.c:603
#, c-format
msgid "Channel \"%s\" contains no properties"
msgstr "O canal \"%s\" não possui propriedades"
